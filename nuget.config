<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-local NuGet sources. <clear/> drops any inherited machine/user-level sources (including
  private feeds) so this PUBLIC repo restores exclusively from nuget.org. Keeps builds reproducible
  for outside contributors and guarantees no private feed is ever pulled or referenced here.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
